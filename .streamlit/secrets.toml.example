# Copy this file to .streamlit/secrets.toml and fill in your own values.
# On Streamlit Community Cloud, paste the same content into
# "App settings" -> "Secrets" instead of committing a real secrets.toml.
#
# Setup steps (no Google Cloud Console needed):
# 1. Open your Google Sheet -> Extensions -> Apps Script.
# 2. Paste in the contents of apps_script/Code.gs from this repo.
# 3. In that script, change TOKEN to your own random secret string.
# 4. Deploy -> New deployment -> type "Web app".
#    Execute as: Me. Who has access: Anyone with the link.
# 5. Click Deploy, authorize when prompted, and copy the web app URL.
# 6. Paste the URL and your TOKEN below.

[gsheets_webapp]
url = "https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
token = "your-random-secret-token"
